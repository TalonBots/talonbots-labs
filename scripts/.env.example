# Copy to scripts/.env (gitignored) and fill in if you are NOT using Vault.
# Then:  set -a; source scripts/.env; set +a
#
# Create your own service principal:
#   az ad sp create-for-rbac --name my-demo-sp --role Contributor \
#     --scopes /subscriptions/<your-sub-id>
#
# Use the secret VALUE (the "password" field), not the secret's ID.

ARM_CLIENT_ID="00000000-0000-0000-0000-000000000000"
ARM_CLIENT_SECRET="your-sp-secret-value-here"
ARM_TENANT_ID="00000000-0000-0000-0000-000000000000"
ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
